# Sony Music Entertainment — Artist Tracker
# ==========================================
# Canonical curated list of artists tracked by the daily pipeline.
# This file is the authoritative source: scripts/build_roster.py reads it
# and produces data/roster.json, which the pipeline + frontend consume.
#
# To add an artist:     append a block, run `npm run pipeline`, commit.
# To remove an artist:  delete the block (or set status: archived to keep
#                       historical snapshots/news intact).
# To update an artist:  edit fields, commit. The pipeline picks it up on
#                       the next run.
#
# Field reference: see skill/references/curated-artists.md
#
# IMPORTANT — slug stability:
#   The `slug` field is the immutable key used across data/snapshots/,
#   data/images/, and frontend routing. NEVER change a slug for an
#   existing artist; rename the display `name` instead. If you must
#   change a slug, also rename historical files in data/snapshots/
#   and data/images/.

version: "1.0"
updated: "2026-04-29"
maintainer: "praveer@chromadata.com"
source: "Customer-provided curated list, 2026-04-29"

