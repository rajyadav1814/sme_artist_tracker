# ── Pipeline notifications (scripts/notify.py) ────────────────────────────────
# When SMTP_* are set, scripts/cron_refresh.sh emails on every failure and on
# every success up to SUCCESS_EMAIL_UNTIL. When SMTP isn't configured the
# notifier writes records to logs/notifications.log instead — pipeline still runs.

# Recipient (override if needed)
NOTIFY_EMAIL_TO=praveer@chromadata.com

# SMTP server. Examples:
#   Gmail:    SMTP_HOST=smtp.gmail.com  SMTP_PORT=587   (use an App Password)
#   Outlook:  SMTP_HOST=smtp-mail.outlook.com  SMTP_PORT=587
#   iCloud:   SMTP_HOST=smtp.mail.me.com  SMTP_PORT=587
#   SendGrid: SMTP_HOST=smtp.sendgrid.net SMTP_PORT=587 SMTP_USER=apikey
#             SMTP_PASSWORD=<your-api-key>
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=                       # optional — defaults to SMTP_USER

# Success-email window. Set to a YYYY-MM-DD string; the wrapper sends a daily
# success summary on or before this date. After this date, only failures email.
SUCCESS_EMAIL_UNTIL=2026-06-10
