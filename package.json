{
  "name": "sme-artist-tracker",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "start": "serve -s dist -l $PORT",
    "build:full": "npm run pipeline && npm run build",
    "pipeline": ".venv/bin/python scripts/run_pipeline.py",
